# ── Extension (WXT, build-time WXT_ prefix) ───────────────────────────────
# The Tacto API + web origins the extension talks to.
#   Local:  http://localhost:4100  /  http://localhost:3100
#   Prod:   https://api.tacto.fyi   /  https://tacto.fyi
WXT_API_BASE=http://localhost:4100
WXT_APP_URL=http://localhost:3100

# PostHog product analytics (optional — a no-op when unset). US region.
# Events post directly to the ingest host (no reverse proxy in the extension).
WXT_POSTHOG_KEY=
WXT_POSTHOG_HOST=https://us.i.posthog.com
