NODE_ENV=development
PORT=4100

# Neon PostgreSQL — https://console.neon.tech
DATABASE_URL=

# Generate: openssl rand -base64 32
BETTER_AUTH_SECRET=
# Public origin auth is reached through (the web app proxies /api/*)
BETTER_AUTH_URL=http://localhost:3100
WEB_ORIGIN=http://localhost:3100

# Google OAuth (optional)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Redis — BullMQ queue the API enqueues jobs onto (worker consumes them).
REDIS_URL=redis://localhost:6379

# Cloudflare R2 (screenshots + exports) — https://dash.cloudflare.com → R2
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=

# AI providers
AI_PROVIDER=openai
AI_MODEL=gpt-5-mini
OPENAI_API_KEY=
# ANTHROPIC_API_KEY=
# Voice-over narration (ElevenLabs)
ELEVENLABS_API_KEY=

# PostHog product analytics (optional — a no-op when unset). US region.
POSTHOG_KEY=
POSTHOG_HOST=https://us.i.posthog.com

# PostHog Logs via OpenTelemetry (optional — logs go to stdout only when unset).
# Get the endpoint + auth header from PostHog → Logs → Node.js setup.
# OTEL_EXPORTER_OTLP_ENDPOINT=https://us.i.posthog.com
# OTEL_EXPORTER_OTLP_HEADERS=Authorization=Bearer phc_your_key
