{
  "name": "worker",
  "version": "0.0.1",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "tsx watch --env-file=.env src/index.ts",
    "start": "tsx --env-file=.env src/index.ts",
    "start:prod": "tsx src/index.ts",
    "build": "tsc --noEmit",
    "typecheck": "tsc --noEmit",
    "test": "tsx src/pipeline/select-frames.test.ts && tsx src/pipeline/compile-interactions.test.ts",
    "lint": "eslint",
    "format": "prettier --write \"**/*.{ts,tsx}\""
  },
  "dependencies": {
    "@workspace/ai": "*",
    "@workspace/analytics": "*",
    "@workspace/contracts": "*",
    "@workspace/db": "*",
    "@workspace/generation": "*",
    "@workspace/observability": "*",
    "@workspace/storage": "*",
    "bullmq": "^5.79.3",
    "execa": "^9.6.1",
    "ffmpeg-static": "^5.3.0",
    "sharp": "^0.34.2",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^20",
    "@workspace/eslint-config": "*",
    "@workspace/typescript-config": "*",
    "eslint": "^9",
    "tsx": "^4.23.0",
    "typescript": "^5"
  }
}
