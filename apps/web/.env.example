# ── Web (Next.js) ─────────────────────────────────────────────────────────
# Every var here has a code fallback, so local dev works with NO .env. But in
# PRODUCTION set them explicitly — never ship on the fallbacks (the API_URL
# fallback points at localhost and would break every API call on Vercel).

# The Express API origin. /api/* is proxied here, and all server-side fetches
# (guides, help centers, showcases, forms, sitemap) hit it.
#   Local:  http://localhost:4100
#   Prod:   https://api.tacto.fyi
# NOTE: baked at BUILD time on Vercel — set it before the build, not after.
API_URL=http://localhost:4100

# Public origin the site is served from — used for metadataBase, canonical
# URLs, Open Graph, robots.txt, and sitemap.xml.
#   Prod: https://tacto.fyi
NEXT_PUBLIC_SITE_URL=https://tacto.fyi

# shareIds of the two published guides shown in the landing-page embeds
# (hero + the scroll/walkthrough demo). Optional — defaults are real guides.
NEXT_PUBLIC_DEMO_GUIDE=uMj-0VML35Pa
NEXT_PUBLIC_DEMO_GUIDE_TOGGLE=uv9If_7NHl8y

# ── PostHog product analytics (optional — a no-op when unset) ──────────────
# Project token + US app host. Ingestion is reverse-proxied through /ingest,
# so nothing else is needed. Marketing + dashboard only; public/embed pages
# never load PostHog.
NEXT_PUBLIC_POSTHOG_PROJECT_TOKEN=
NEXT_PUBLIC_POSTHOG_HOST=https://us.posthog.com
# Optional build metadata attached to every event.
# NEXT_PUBLIC_APP_VERSION=
# NEXT_PUBLIC_BUILD_SHA=
