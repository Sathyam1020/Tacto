// Tacto database schema.
// Prisma 7: the datasource URL lives in prisma.config.ts, not here.
//
// Auth + organization models follow better-auth's generated schema exactly
// (cross-checked with `npx @better-auth/cli generate`). Organizations are
// Tacto "workspaces" — Organization in code, Workspace in UI copy.

generator client {
  provider = "prisma-client"
  output   = "../src/generated"
}

datasource db {
  provider = "postgresql"
}

// ── better-auth core models ──────────────────────────────────────────────

model User {
  id            String   @id @default(uuid())
  name          String
  email         String   @unique
  emailVerified Boolean  @default(false)
  image         String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  sessions    Session[]
  accounts    Account[]
  members     Member[]
  invitations Invitation[]
  captures    Capture[]
  guides      Guide[]

  @@map("user")
}

model Session {
  id        String   @id @default(uuid())
  expiresAt DateTime
  token     String   @unique
  ipAddress String?
  userAgent String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  /// Active workspace for this session (better-auth organization plugin).
  activeOrganizationId String?

  @@index([userId])
  @@map("session")
}

model Account {
  id                    String    @id @default(uuid())
  accountId             String
  providerId            String
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("account")
}

model Verification {
  id         String   @id @default(uuid())
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([identifier])
  @@map("verification")
}

// ── Workspaces (better-auth organization plugin) ─────────────────────────

model Organization {
  id        String   @id @default(uuid())
  name      String
  slug      String   @unique
  logo      String?
  metadata  String?
  createdAt DateTime @default(now())

  members     Member[]
  invitations Invitation[]
  captures    Capture[]
  guides      Guide[]
  folders     Folder[]

  @@map("organization")
}

/// A folder groups guides within a workspace. Flat (no nesting); a guide
/// belongs to at most one folder (folderId null = uncategorized / All guides).
model Folder {
  id        String   @id @default(uuid())
  name      String
  /// The workspace's default folder — new/uncategorized guides land here, and
  /// it can't be deleted (exactly one per workspace).
  isDefault Boolean  @default(false)
  /// Manual sort order within the workspace (lower = higher in the list).
  position  Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  guides   Guide[]
  captures Capture[]

  @@index([organizationId])
  @@map("folder")
}

model Member {
  id        String   @id @default(uuid())
  role      String   @default("member")
  createdAt DateTime @default(now())

  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  userId         String
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@index([userId])
  @@map("member")
}

model Invitation {
  id        String   @id @default(uuid())
  email     String
  role      String?
  status    String   @default("pending")
  expiresAt DateTime
  createdAt DateTime @default(now())

  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  inviterId      String
  user           User         @relation(fields: [inviterId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@index([email])
  @@map("invitation")
}

// ── Product spine: Capture → Guide → Step ────────────────────────────────
// All rows are workspace-scoped (organizationId). Capture and Guide use
// soft deletes (deletedAt) — queries must filter deletedAt: null.

enum CaptureSource {
  EXTENSION
  VIDEO_UPLOAD
  IMPORT
}

enum CaptureStatus {
  UPLOADING
  PROCESSING
  READY
  FAILED
}

enum GuideStatus {
  DRAFT
  PUBLISHED
}

/// A guide is an ordered list of typed blocks. Only STEP blocks are numbered
/// in display; HEADING/TIP/ALERT are annotations between steps.
enum BlockType {
  STEP
  HEADING
  TIP
  ALERT
  // Outcome/result: a confirmation of what the user now sees after the final
  // view-opening action (no action, no pointer). Presentation-only.
  OUTCOME
}

/// Immutable raw material: the recorded event log. Never edited after
/// completion — Guides are the editable derivative, and better models can
/// reprocess the same Capture later.
model Capture {
  id           String        @id @default(uuid())
  source       CaptureSource
  status       CaptureStatus @default(UPLOADING)
  title        String?
  /// Normalized event log (contracts captureEventSchema[]). Written at
  /// creation for event captures; derived by video ingestion for uploads.
  events       Json?
  /// R2 object key of the raw recording (video captures).
  videoKey     String?
  durationSec  Float?
  errorMessage String?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  deletedAt    DateTime?

  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  createdById    String
  createdBy      User         @relation(fields: [createdById], references: [id], onDelete: Cascade)
  /// Folder the resulting guide should land in (chosen at record time; null =
  /// the workspace's default folder).
  folderId       String?
  folder         Folder?      @relation(fields: [folderId], references: [id], onDelete: SetNull)

  guides Guide[]

  @@index([organizationId, status])
  @@map("capture")
}

/// The editable document derived from a Capture. One Capture can produce
/// many Guides (reprocessing, translations later).
model Guide {
  id        String      @id @default(uuid())
  title     String
  summary   String?
  status    GuideStatus @default(DRAFT)
  /// Public unlisted-link identifier (nanoid), set on first publish.
  shareId     String?   @unique
  publishedAt DateTime?
  viewCount   Int       @default(0)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  deletedAt   DateTime?
  /// When pinned to the top of the workspace list (null = not pinned).
  pinnedAt    DateTime?

  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  captureId      String?
  capture        Capture?     @relation(fields: [captureId], references: [id], onDelete: SetNull)
  createdById    String
  createdBy      User         @relation(fields: [createdById], references: [id], onDelete: Cascade)
  /// Folder grouping within the workspace (null = uncategorized). Deleting the
  /// folder leaves the guide uncategorized rather than removing it.
  folderId       String?
  folder         Folder?      @relation(fields: [folderId], references: [id], onDelete: SetNull)

  blocks Step[]

  @@index([organizationId, status])
  @@index([organizationId, folderId])
  @@map("guide")
}

/// Ephemeral hint: the folder the user's next extension capture should land in.
/// The web sets it at record-start (the extension can't reliably carry state
/// across an MV3 service-worker restart); the capture-create consumes + clears
/// it. One per (user, workspace). Not FK-constrained — a stale/deleted folder
/// is simply validated away at consume time (falls back to the default folder).
model CaptureIntent {
  userId         String
  organizationId String
  folderId       String
  updatedAt      DateTime @updatedAt

  @@id([userId, organizationId])
  @@map("capture_intent")
}

/// A content block within a guide (table name kept as "step" for history).
/// `content` is sanitized HTML. Media/interaction fields apply to STEP only.
model Step {
  id            String    @id @default(uuid())
  type          BlockType @default(STEP)
  position      Int
  content       String
  elementLabel  String?
  url           String?
  screenshotUrl String?
  /// { x, y, w, h } of the interaction target, viewport coordinates.
  boundingBox   Json?
  /// Normalized { x, y, w, h } (0–1 of the screenshot) — the click pointer.
  clickRect     Json?
  /// 0–1; below ~0.7 the editor flags the step for review (video imports).
  confidence    Float?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  guideId String
  guide   Guide  @relation(fields: [guideId], references: [id], onDelete: Cascade)

  @@index([guideId, position])
  @@map("step")
}
