// Tacto database schema.
// Prisma 7: the datasource URL lives in prisma.config.ts, not here.
//
// Auth + organization models follow better-auth's generated schema exactly
// (cross-checked with `npx @better-auth/cli generate`). Organizations are
// Tacto "workspaces" — Organization in code, Workspace in UI copy.

generator client {
  provider = "prisma-client"
  output   = "../src/generated"
}

datasource db {
  provider = "postgresql"
}

// ── better-auth core models ──────────────────────────────────────────────

model User {
  id            String   @id @default(uuid())
  name          String
  email         String   @unique
  emailVerified Boolean  @default(false)
  image         String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  sessions    Session[]
  accounts    Account[]
  members     Member[]
  invitations Invitation[]
  captures    Capture[]
  guides      Guide[]
  forms       Form[]

  @@map("user")
}

model Session {
  id        String   @id @default(uuid())
  expiresAt DateTime
  token     String   @unique
  ipAddress String?
  userAgent String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  /// Active workspace for this session (better-auth organization plugin).
  activeOrganizationId String?

  @@index([userId])
  @@map("session")
}

model Account {
  id                    String    @id @default(uuid())
  accountId             String
  providerId            String
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("account")
}

model Verification {
  id         String   @id @default(uuid())
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([identifier])
  @@map("verification")
}

// ── Workspaces (better-auth organization plugin) ─────────────────────────

model Organization {
  id        String   @id @default(uuid())
  name      String
  slug      String   @unique
  logo      String?
  metadata  String?
  createdAt DateTime @default(now())

  members     Member[]
  invitations Invitation[]
  captures    Capture[]
  guides      Guide[]
  folders     Folder[]
  forms       Form[]

  @@map("organization")
}

/// Which library a folder belongs to. Forms and Guides keep independent folder
/// namespaces even though they share this table.
enum FolderKind {
  GUIDE
  FORM
}

/// A folder groups guides OR forms within a workspace (never both — see `kind`).
/// Flat (no nesting); an item belongs to at most one folder (folderId null =
/// uncategorized / All).
model Folder {
  id        String   @id @default(uuid())
  name      String
  /// The library this folder belongs to. Guide and Form folders are disjoint.
  kind      FolderKind @default(GUIDE)
  /// The workspace's default folder for this kind — new/uncategorized items land
  /// here, and it can't be deleted (exactly one per workspace per kind).
  isDefault Boolean  @default(false)
  /// Manual sort order within the workspace (lower = higher in the list).
  position  Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  guides   Guide[]
  captures Capture[]
  forms    Form[]

  @@index([organizationId])
  @@map("folder")
}

model Member {
  id        String   @id @default(uuid())
  role      String   @default("member")
  createdAt DateTime @default(now())

  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  userId         String
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@index([userId])
  @@map("member")
}

model Invitation {
  id        String   @id @default(uuid())
  email     String
  role      String?
  status    String   @default("pending")
  expiresAt DateTime
  createdAt DateTime @default(now())

  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  inviterId      String
  user           User         @relation(fields: [inviterId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@index([email])
  @@map("invitation")
}

// ── Product spine: Capture → Guide → Step ────────────────────────────────
// All rows are workspace-scoped (organizationId). Capture and Guide use
// soft deletes (deletedAt) — queries must filter deletedAt: null.

enum CaptureSource {
  EXTENSION
  VIDEO_UPLOAD
  IMPORT
}

enum CaptureStatus {
  UPLOADING
  PROCESSING
  READY
  FAILED
}

enum GuideStatus {
  DRAFT
  PUBLISHED
}

enum FormStatus {
  DRAFT
  PUBLISHED
}

/// A form (survey/quiz/application). Published content is a JSON document
/// (fields + thankYou + design + settings) — not a relational field table —
/// mirroring how Guide carries customization/interactive as JSON. Shape =
/// FormDocument in @workspace/contracts/form.
model Form {
  id          String     @id @default(uuid())
  title       String
  description String?
  status      FormStatus @default(DRAFT)
  /// Unlisted public id, minted (nanoid) on first publish; stable across republishes.
  shareId     String?    @unique
  publishedAt DateTime?
  pinnedAt    DateTime?
  deletedAt   DateTime?

  /// Published form document. Null until first publish.
  document Json?
  /// Monotonic version, incremented on every successful publish. Submissions
  /// record the version they were filled against (for future reporting).
  documentVersion Int @default(0)

  /// Analytics counters (fire-and-forget increments; never block a response).
  viewCount   Int @default(0)
  startCount  Int @default(0)
  submitCount Int @default(0)

  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  createdById    String
  createdBy      User         @relation(fields: [createdById], references: [id], onDelete: Cascade)
  folderId       String?
  folder         Folder?      @relation(fields: [folderId], references: [id], onDelete: SetNull)

  draft       FormDraft?
  submissions FormSubmission[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([organizationId, status])
  @@index([organizationId, folderId])
  @@map("form")
}

/// The editable working document for a form (one per form), versioned for
/// optimistic-concurrency autosave. Mirrors GuideDraft.
model FormDraft {
  id              String   @id @default(uuid())
  formId          String   @unique
  form            Form     @relation(fields: [formId], references: [id], onDelete: Cascade)
  document        Json
  version         Int      @default(1)
  updatedByUserId String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@map("form_draft")
}

/// A public submission — answers keyed by stable field key, plus the form
/// document version it was submitted against.
model FormSubmission {
  id          String   @id @default(uuid())
  formId      String
  form        Form     @relation(fields: [formId], references: [id], onDelete: Cascade)
  anonId      String?
  answers     Json
  formVersion Int
  durationMs  Int?
  metadata    Json?
  createdAt   DateTime @default(now())

  @@index([formId, createdAt])
  @@map("form_submission")
}

/// A guide is an ordered list of typed blocks. Only STEP blocks are numbered
/// in display; HEADING/TIP/ALERT are annotations between steps.
enum BlockType {
  STEP
  HEADING
  TIP
  ALERT
  // Outcome/result: a confirmation of what the user now sees after the final
  // view-opening action (no action, no pointer). Presentation-only.
  OUTCOME
}

/// Immutable raw material: the recorded event log. Never edited after
/// completion — Guides are the editable derivative, and better models can
/// reprocess the same Capture later.
model Capture {
  id           String        @id @default(uuid())
  source       CaptureSource
  status       CaptureStatus @default(UPLOADING)
  title        String?
  /// Normalized event log (contracts captureEventSchema[]). Written at
  /// creation for event captures; derived by video ingestion for uploads.
  events       Json?
  /// R2 object key of the raw recording (video captures).
  videoKey     String?
  durationSec  Float?
  errorMessage String?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  deletedAt    DateTime?

  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  createdById    String
  createdBy      User         @relation(fields: [createdById], references: [id], onDelete: Cascade)
  /// Folder the resulting guide should land in (chosen at record time; null =
  /// the workspace's default folder).
  folderId       String?
  folder         Folder?      @relation(fields: [folderId], references: [id], onDelete: SetNull)

  guides Guide[]

  @@index([organizationId, status])
  @@map("capture")
}

/// The editable document derived from a Capture. One Capture can produce
/// many Guides (reprocessing, translations later).
model Guide {
  id        String      @id @default(uuid())
  title     String
  summary   String?
  status    GuideStatus @default(DRAFT)
  /// Public unlisted-link identifier (nanoid), set on first publish.
  shareId     String?   @unique
  publishedAt DateTime?
  viewCount   Int       @default(0)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  deletedAt   DateTime?
  /// When pinned to the top of the workspace list (null = not pinned).
  pinnedAt    DateTime?
  /// Published-view customization (theme, hotspot, layout, walkthrough, …).
  /// Null = defaults. Shape lives in @workspace/contracts/guide.
  customization Json?
  /// Published Interactive (Walkthrough) tree — the mode-specific content
  /// (step items + intro/chapter slides). Null = seed from `blocks` on read.
  /// Shape = WalkthroughTree in @workspace/contracts/guide.
  interactive   Json?
  /// Published FAQ list ({question, answer, source}[], max 5). Null = none.
  /// Shape = Faq[] in @workspace/contracts/guide.
  faqs          Json?
  /// Published form embeds (overlays shown in the guide). Null = none.
  /// Shape = FormEmbed[] in @workspace/contracts/guide.
  embeds        Json?

  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  captureId      String?
  capture        Capture?     @relation(fields: [captureId], references: [id], onDelete: SetNull)
  createdById    String
  createdBy      User         @relation(fields: [createdById], references: [id], onDelete: Cascade)
  /// Folder grouping within the workspace (null = uncategorized). Deleting the
  /// folder leaves the guide uncategorized rather than removing it.
  folderId       String?
  folder         Folder?      @relation(fields: [folderId], references: [id], onDelete: SetNull)

  blocks       Step[]
  draft        GuideDraft?
  translations GuideTranslation[]
  reactions    GuideReaction[]
  comments     GuideComment[]
  narrations   Narration[]
  mediaRenders MediaRender[]

  @@index([organizationId, status])
  @@index([organizationId, folderId])
  @@map("guide")
}

/// A guide's private working draft — one versioned JSON document per guide.
/// The editor reads and autosaves this; the published Guide/Step rows are
/// only changed by an explicit Publish. See DraftDocument in @workspace/contracts.
model GuideDraft {
  id              String   @id @default(uuid())
  guideId         String   @unique
  guide           Guide    @relation(fields: [guideId], references: [id], onDelete: Cascade)
  /// DraftDocument JSON (title, summary, blocks, customization).
  document        Json
  /// Optimistic-concurrency counter, bumped on every autosave.
  version         Int      @default(1)
  /// Audit: the user who last wrote the draft (no FK — metadata only).
  updatedByUserId String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@map("guide_draft")
}

/// AI-translated copy of a guide's text (title + per-step content) in another
/// language. Screenshots are shared; only text is translated.
model GuideTranslation {
  id        String   @id @default(uuid())
  guideId   String
  guide     Guide    @relation(fields: [guideId], references: [id], onDelete: Cascade)
  /// Stored as a language code (e.g. "es", "fr", "ar").
  language  String
  title     String
  summary   String?
  /// { blockKey: translatedContent } — translated block content keyed by the
  /// block's STABLE key (v3). Legacy rows hold [{ index, content }] and are
  /// migrated on read against the current block order.
  steps     Json
  /// { slideStringId: translatedText } — slide title/subtitle/button text keyed
  /// by stable ids (`${slideKey}#title` / `#subtitle` / buttonKey). Null = none.
  interactive Json?
  /// The source strings this translation was generated from ({ title, summary,
  /// steps, slides }), captured so the editor can detect drift and re-translate
  /// individual steps. Null on legacy rows (pre-capture) → staleness unknown.
  source    Json?
  /// Async generation status: generating | ready | failed. The editor polls it.
  status    String   @default("ready")
  /// Failure detail when status = failed.
  error     String?
  /// Hidden from the public reader until the editor Saves the guide.
  published Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([guideId, language])
  @@map("guide_translation")
}

/// A reaction on a published guide from an anonymous viewer (localStorage id).
model GuideReaction {
  id        String   @id @default(uuid())
  guideId   String
  guide     Guide    @relation(fields: [guideId], references: [id], onDelete: Cascade)
  emoji     String
  anonId    String
  createdAt DateTime @default(now())

  @@unique([guideId, anonId, emoji])
  @@index([guideId])
  @@map("guide_reaction")
}

/// A comment on a guide (team members in-app, or public viewers if allowed).
model GuideComment {
  id          String   @id @default(uuid())
  guideId     String
  guide       Guide    @relation(fields: [guideId], references: [id], onDelete: Cascade)
  authorName  String
  authorId    String?
  body        String
  createdAt   DateTime @default(now())

  @@index([guideId, createdAt])
  @@map("guide_comment")
}

/// Ephemeral hint: the folder the user's next extension capture should land in.
/// The web sets it at record-start (the extension can't reliably carry state
/// across an MV3 service-worker restart); the capture-create consumes + clears
/// it. One per (user, workspace). Not FK-constrained — a stale/deleted folder
/// is simply validated away at consume time (falls back to the default folder).
model CaptureIntent {
  userId         String
  organizationId String
  folderId       String
  updatedAt      DateTime @updatedAt

  @@id([userId, organizationId])
  @@map("capture_intent")
}

/// A content block within a guide (table name kept as "step" for history).
/// `content` is sanitized HTML. Media/interaction fields apply to STEP only.
model Step {
  id            String    @id @default(uuid())
  /// Stable block identity, carried across publishes so references to a block
  /// (drafts, translations, per-step features) survive a save. Assigned on
  /// create; unique within a guide.
  key           String    @default(uuid())
  type          BlockType @default(STEP)
  position      Int
  content       String
  elementLabel  String?
  url           String?
  screenshotUrl String?
  /// { x, y, w, h } of the interaction target, viewport coordinates.
  boundingBox   Json?
  /// Normalized { x, y, w, h } (0–1 of the screenshot) — the click pointer.
  clickRect     Json?
  /// 0–1; below ~0.7 the editor flags the step for review (video imports).
  confidence    Float?
  /// Per-step overrides of the guide customization: { imageScaling?, zoomLevel? }.
  settings      Json?
  /// R2 key of a per-step voiceover (reserved; the voiceover feature is later).
  voiceoverUrl  String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  guideId String
  guide   Guide  @relation(fields: [guideId], references: [id], onDelete: Cascade)

  @@unique([guideId, key])
  @@index([guideId, position])
  @@map("step")
}

// ── Voice subsystem (Narration → Media Render) ───────────────────────────
// Narration is the canonical, editable, per-language script keyed by the
// sequence's stable keys (Step.key / slide.key / intro / outro). Rendered
// media (audio today; avatar/video later) are disposable, content-addressed
// artifacts derived from narration + voice settings. Voice settings live in the
// guide customization (draft/publish-versioned). See the Voice RFC and
// @workspace/contracts/voice.

/// A per-language narration script for a guide. Base language ("en") is the
/// source; other rows mirror translations. Published narration is what the
/// public reader hears — drafts stay hidden until the guide is Updated.
model Narration {
  id        String   @id @default(uuid())
  guideId   String
  guide     Guide    @relation(fields: [guideId], references: [id], onDelete: Cascade)
  /// Language code ("en" for the base guide, else "fr", "es", …).
  language  String
  /// Async generation status: idle | generating | ready | failed. Editor polls.
  status    String   @default("ready")
  /// Failure detail when status = failed.
  error     String?
  /// Hidden from the public reader until the editor Updates the guide.
  published Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  segments NarrationSegment[]

  @@unique([guideId, language])
  @@map("narration")
}

/// One spoken unit of a narration, anchored to a stable sequence key. `text`
/// is the source of truth; audio is a derived render (see MediaRender).
model NarrationSegment {
  id                String    @id @default(uuid())
  narrationId       String
  narration         Narration @relation(fields: [narrationId], references: [id], onDelete: Cascade)
  /// Step.key | slide.key | reserved intro/outro anchors.
  anchorKey         String
  /// The spoken script (plain text; provider-neutral).
  text              String
  /// Optional provider-neutral structure/overrides (pause, emphasis, style).
  markup            Json?
  /// True once a human edits the text — regeneration flags, never overwrites.
  humanEdited       Boolean   @default(false)
  /// Hash of the upstream source (localized step/slide text) at write time; a
  /// mismatch vs. the current guide means this narration is stale.
  sourceFingerprint String?
  /// pending | ready | failed.
  status            String    @default("ready")
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  renderRefs SegmentRenderRef[]

  @@unique([narrationId, anchorKey])
  @@map("narration_segment")
}

/// A content-addressed, immutable render artifact derived from a narration
/// segment + voice config. `renderHash` is the identity: same inputs → same
/// row → same R2 object (no re-synthesis). Per-guide namespaced for lifecycle.
model MediaRender {
  id         String   @id @default(uuid())
  guideId    String
  guide      Guide    @relation(fields: [guideId], references: [id], onDelete: Cascade)
  /// sha256 of (kind, provider, model, voiceId, format, speed, style, payload).
  renderHash String
  /// audio (future: avatar-video, export-mp4, podcast).
  kind       String
  provider   String
  model      String?
  voiceId    String
  format     String
  speed      Float?
  /// Extra provider params captured for reproducibility.
  params     Json?
  /// Language code the render belongs to (for pathing/GC; identity is the hash).
  language   String?
  /// R2 object key; null until status = ready.
  r2Key      String?
  durationMs Int?
  sizeBytes  Int?
  /// pending | ready | failed.
  status     String   @default("pending")
  error      String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  refs SegmentRenderRef[]

  @@unique([guideId, renderHash])
  @@index([guideId, status])
  @@map("media_render")
}

/// Which render a narration segment currently resolves to, per media kind.
/// Separating this from the segment (script) and the render (artifact) keeps
/// three lifecycles clean and lets multiple kinds coexist per segment.
model SegmentRenderRef {
  id        String           @id @default(uuid())
  segmentId String
  segment   NarrationSegment @relation(fields: [segmentId], references: [id], onDelete: Cascade)
  /// audio (future kinds share the segment).
  kind      String
  renderId  String
  render    MediaRender      @relation(fields: [renderId], references: [id], onDelete: Cascade)
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt

  @@unique([segmentId, kind])
  @@map("segment_render_ref")
}
